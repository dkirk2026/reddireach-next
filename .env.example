# Sanity blog source (PUBLIC dataset — not secrets). The site builds with these
# defaults baked in, so this file is optional.
NEXT_PUBLIC_SANITY_PROJECT_ID=vj3ex5iz
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Google Analytics 4 — defaults to the live ReddiReach property. Override or set
# empty to disable.
NEXT_PUBLIC_GA4_ID=G-C3W16CY6DX

# On-demand revalidation secret. Set this to any random string and use the same
# value in the Sanity webhook URL (?secret=...) so publishing a post instantly
# refreshes the blog. See README "Instant blog publishing".
SANITY_REVALIDATE_SECRET=
